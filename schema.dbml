enum actions {
  create
  update
  delete
  massDelete
  emailSent
  softDelete
}

enum attempt_status {
  Started
  Submitted
  Graded
}

enum payment_method {
  card
  bankTransfer
  cash
  free
}

enum promo_code_type {
  percentage
  amount
}

enum duration_unit {
  hours
  days
  months
}

enum published_status {
  published
  hidden
  draft
}

enum question_type {
  SingleChoice
  MultipleChoice
  Text
  FileUpload
}

enum refund_reason {
  duplicate
  fraudulent
  requested_by_customer
}

enum refund_type {
  full
  partial
}

enum role {
  admin
  teacher
  student
  parent
}

enum video_status {
  pending
  uploaded
  processing
  failed
}

table password_reset_tokens {
  token text [pk, not null]
  user_id text [not null]
  expires_at "timestamp (3) with time zone" [not null]
}

table sessions {
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"
  id text [pk, not null]
  user_id text [not null]
  expires_at "timestamp with time zone" [not null]
}

table users {
  id text [pk, not null]
  google_id text [unique]
  first_name varchar(180) [not null]
  last_name varchar(180) [not null]
  email varchar(255) [not null, unique]
  password_hash text [not null]
  role role
  refresh_token text
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    email [name: 'user_email_idx']
    role [name: 'user_role_idx']
    created_at [name: 'user_created_at_idx']
    deleted_at [name: 'user_deleted_at_idx']
  }
}

table user_permissions {
  id serial [pk, not null, increment]
  permissions json [not null, default: `{"ViewVideos":false,"UploadVideos":false,"EditVideos":false,"DeleteVideos":false,"UploadFiles":false,"DeleteFiles":false,"ViewSubjects":false,"CreateSubjects":false,"EditSubjects":false,"DeleteSubjects":false,"ViewClassGrades":false,"CreateClassGrades":false,"EditClassGrades":false,"DeleteClassGrades":false,"ViewLessonGroups":false,"CreateLessonGroups":false,"EditLessonGroups":false,"DeleteLessonGroups":false,"ViewTests":false,"CreateTests":false,"EditTests":false,"DeleteTests":false,"ViewLessons":false,"CreateLessons":false,"EditLessons":false,"DeleteLessons":false,"ViewEvents":false,"CreateEvents":false,"EditEvents":false,"DeleteEvents":false,"ViewComments":false,"ModerateComments":false,"ViewTransactions":false,"ViewRefunds":false,"CreateRefunds":false,"ViewUsers":false,"CreateUsers":false,"EditUsers":false,"DeleteUsers":false,"ViewAdmins":false,"CreateAdmins":false,"EditAdmins":false,"DeleteAdmins":false}`]
  user_id text [not null]
}

table videos {
  id text [pk, not null]
  file_key text [not null, unique]
  original_name text [not null]
  content_type text [not null]
  size bigint [not null]
  display_name text [not null]
  thumbnails_key text
  status video_status [not null, default: 'pending']
  subject_id integer
  class_grade_id integer
  uploaded_by_id text
  poster_file_id text
  chapters_file_id text
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    status [name: 'video_status_idx']
    uploaded_by_id [name: 'video_uploaded_by_idx']
    file_key [name: 'video_file_key_idx']
    created_at [name: 'video_created_at_idx']
    deleted_at [name: 'video_deleted_at_idx']
  }
}

table files {
  id text [pk, not null]
  file_key text [not null, unique]
  original_name text [not null]
  content_type text [not null]
  size bigint [not null]
  display_name text [not null]
  uploaded_by_id text
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    uploaded_by_id [name: 'file_uploaded_by_idx']
    file_key [name: 'file_file_key_idx']
    created_at [name: 'file_created_at_idx']
    deleted_at [name: 'file_deleted_at_idx']
  }
}

table test_answers {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  attempt_id uuid [not null]
  question_id uuid [not null]
  response jsonb
  awarded_score real [not null, default: 0]
  answered_at "timestamp (3) with time zone"

  indexes {
    attempt_id [name: 'answers_attempt_idx']
    (attempt_id, question_id) [name: 'answers_attempt_question_uk', unique]
  }
}

table test_attempts {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  test_id uuid [not null]
  user_id text [not null]
  attempt_number integer [not null]
  status attempt_status [not null, default: 'Started']
  started_at "timestamp (3) with time zone" [not null, default: `now()`]
  submitted_at "timestamp (3) with time zone"
  graded_at "timestamp (3) with time zone"
  total_score real [not null, default: 0]
  reviewer_observations text
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    (test_id, user_id, attempt_number) [name: 'attempts_test_user_attempt_number_uk', unique]
  }
}

table test_questions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  test_id uuid [not null]
  order integer [not null, default: 0]
  type question_type [not null]
  stem text [not null]
  points real [not null, default: 1]
  config jsonb [not null]
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    (test_id, order) [name: 'questions_test_order_uk', unique]
  }
}

table tests {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  author_id text
  last_edited_by_id text
  title text [not null]
  allowed_attempts integer [not null, default: 0]
  description text [not null]
  time_limit_sec integer [not null, default: 0]
  opens_at "timestamp (3) with time zone"
  closes_at "timestamp (3) with time zone"
  questions_per_page integer [not null, default: 3]
  max_score real [not null, default: 0]
  subject_id integer [not null]
  class_grade_id integer [not null]
  is_paid boolean [not null, default: false]
  is_featured boolean [not null, default: false]
  featured_order integer [not null, default: 0]
  price_in_cents integer [not null, default: 0]
  published_status published_status [not null, default: 'draft']
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"
}

table paid_test_entries {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id text [not null]
  test_id uuid [not null]
  paid_at "timestamp (3) with time zone"
  external_checkout_session_id text
  external_customer_id text
  transaction_id text
  payment_method payment_method [not null, default: 'card']
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    (test_id, user_id, paid_at) [name: 'unique_paid_test_user_id_paid_at_not_null', unique]
  }
}

table class_grades {
  id serial [pk, not null, increment]
  grade_number integer [not null, unique]
  name text [not null, unique]
  slug text [not null, unique]
}

table subjects {
  id serial [pk, not null, increment]
  name text [not null, unique]
  slug text [not null, unique]
  color_from text
  color_to text
}

table lesson_groups {
  id serial [pk, not null, increment]
  name text [not null, unique]
  order integer [not null, default: 1]
  class_grade_id integer [not null]
  subject_id integer [not null]

  indexes {
    (subject_id, class_grade_id, order) [name: 'lesson_chapter_unique_order_per_subject_class_grade_idx', unique]
  }
}

table lessons {
  id text [pk, not null]
  title text [not null]
  content text
  resume text [not null]
  is_paid boolean [not null, default: false]
  published_status published_status [not null, default: 'hidden']
  video_id text [not null]
  subject_id integer [not null]
  class_grade_id integer [not null]
  group_id integer
  test_id uuid
  author_id text
  last_edited_by_id text
  order integer [not null, default: 1]
  view_count integer [not null, default: 0]
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    author_id [name: 'lesson_author_idx']
    created_at [name: 'lesson_created_at_idx']
    deleted_at [name: 'lesson_deleted_at_idx']
    (subject_id, class_grade_id, order) [name: 'lesson_unique_order_per_subject_class_grade_idx', unique]
  }
}

table student_lessons {
  user_id text [not null]
  lesson_id text [not null]
  started_at "timestamp (3) with time zone" [not null, default: `now()`]
  last_accessed_at "timestamp (3) with time zone" [not null, default: `now()`]
  completed_at "timestamp (3) with time zone"
  progress real [not null, default: 0]
  video_progress real [not null, default: 0]

  indexes {
    (user_id, lesson_id) [pk]
    user_id [name: 'student_lessons_user_id_idx']
    lesson_id [name: 'student_lessons_lesson_id_idx']
    started_at [name: 'student_lessons_started_at_idx']
    completed_at [name: 'student_lessons_completed_at_idx']
  }
}

table lesson_comments {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  content text [not null]
  lesson_id text [not null]
  author_id text [not null]
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    author_id [name: 'lesson_comments_author_idx']
    created_at [name: 'lesson_comments_created_at_idx']
    deleted_at [name: 'lesson_comments_deleted_at_idx']
  }
}

table lesson_likes {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  lesson_id text [not null]
  user_id text [not null]
}

table public_events {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  name text [not null]
  description text
  link text
  date "timestamp (3) with time zone" [not null]
  poster_file_id text
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"
}

table public_event_entries {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  event_id uuid [not null]
  atendee_email text [not null]
  atendee_name text [not null]
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    (event_id, atendee_email) [name: 'unique_public_event_email', unique]
  }
}

table paid_events {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  name text [not null]
  description text
  is_redirecting boolean [not null, default: false]
  redirect_url text
  redirect_button_text text
  attributes jsonb [not null, default: `[]`]
  price_in_cents integer [not null, default: 0]
  date "timestamp (3) with time zone" [not null]
  poster_file_id text
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"
}

table paid_event_entries {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  event_id uuid [not null]
  first_name text [not null]
  last_name text [not null]
  atendee_email text [not null]
  phone text [not null]
  paid_at "timestamp (3) with time zone"
  external_checkout_session_id text
  external_customer_id text
  transaction_id text
  payment_method payment_method [not null, default: 'card']
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"

  indexes {
    (event_id, atendee_email, paid_at, first_name, last_name) [name: 'unique_paid_event_email_paid_at_not_null', unique]
  }
}

table transactions {
  created_at "timestamp (3) with time zone" [not null, default: `now()`]
  updated_at "timestamp (3) with time zone" [not null, default: `now()`]
  deleted_at "timestamp (3) with time zone"
  id text [pk, not null]
  order_id serial [not null, unique, increment]
  external_id text [not null, unique]
  amount_in_cents integer [not null]
  reason text [not null]
  last4 varchar(4)
  card_type varchar(255)
  payment_method payment_method [not null, default: 'card']
  email varchar(255) [not null]
  phone varchar(255)
  first_name varchar(255) [not null]
  last_name varchar(255) [not null]

  indexes {
    external_id [name: 'transactions_external_id_idx']
    email [name: 'transactions_email_idx']
    phone [name: 'transactions_phone_idx']
    created_at [name: 'transactions_created_at_idx']
    deleted_at [name: 'transactions_deleted_at_idx']
  }
}

table upload_tokens {
  id text [pk, not null]
  attempt_id uuid [not null]
  question_id uuid [not null]
  user_id text [not null]
  expires_at "timestamp (3) with time zone" [not null]
  created_at "timestamp (3) with time zone" [not null, default: `now()`]

  indexes {
    attempt_id [name: 'upload_tokens_attempt_idx']
    user_id [name: 'upload_tokens_user_idx']
    expires_at [name: 'upload_tokens_expires_at_idx']
  }
}

ref: password_reset_tokens.user_id > users.id

ref: sessions.user_id > users.id

ref: user_permissions.user_id - users.id

