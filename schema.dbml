ref: test_answers.question_id > test_questions.id

ref: test_attempts.test_id > tests.id

ref: test_attempts.user_id > users.id

ref: test_questions.test_id > tests.id

ref: tests.author_id > users.id

ref: tests.last_edited_by_id > users.id

ref: tests.subject_id > subjects.id

ref: tests.class_grade_id > class_grades.id

