ref: paid_test_entries.user_id - users.id

ref: paid_test_entries.transaction_id - transactions.id

ref: lesson_groups.class_grade_id - class_grades.id

ref: lesson_groups.subject_id - subjects.id

ref: lessons.author_id > users.id

ref: lessons.last_edited_by_id > users.id

ref: lessons.video_id > videos.id

ref: lessons.test_id - tests.id

ref: lessons.subject_id > subjects.id

ref: lessons.class_grade_id > class_grades.id

ref: lessons.group_id > lesson_groups.id

ref: student_lessons.user_id > users.id

ref: student_lessons.lesson_id > lessons.id

ref: lesson_comments.author_id - users.id

ref: lesson_comments.lesson_id > lessons.id

ref: lesson_likes.lesson_id > lessons.id

ref: lesson_likes.user_id - users.id

ref: public_events.poster_file_id - files.id

ref: public_event_entries.event_id > public_events.id

ref: paid_events.poster_file_id - files.id

ref: paid_event_entries.event_id > paid_events.id

ref: paid_event_entries.transaction_id - transactions.id

